---
import PageLayout from '../layouts/PageLayout.astro';
import PersonCard from '../components/PersonCard.astro';
import { getStaff, getImageUrl } from '../lib/strapi';
import type { StaffMember } from '../lib/strapi';

const staff = await getStaff();

// Sort by sortOrder (lower = higher), fallback to id for stability
const sortByOrder = (a: StaffMember, b: StaffMember) =>
  (a.sortOrder ?? 0) - (b.sortOrder ?? 0) || a.id - b.id;

// Split into three sections matching Wix layout
const direction = staff.filter(
  (s: StaffMember) =>
    s.roleCategory === 'Administration' &&
    (s.role === 'chancelier' || s.role === 'recteur')
);
const chancelier = direction.find((s: StaffMember) => s.role === 'chancelier');
const recteur = direction.find((s: StaffMember) => s.role === 'recteur');

const administration = staff.filter(
  (s: StaffMember) =>
    s.roleCategory === 'Administration' &&
    s.role !== 'chancelier' &&
    s.role !== 'recteur'
).sort(sortByOrder);

const anciens = staff.filter(
  (s: StaffMember) => s.roleCategory === 'Ancien'
).sort(sortByOrder);
---

<PageLayout
  title="Direction et formateurs"
  overline="Notre équipe"
>
  <section class="equipe-section">
    <div class="container">
      {staff.length === 0 && (
        <div class="equipe-placeholder">
          <p>Les informations sur l'équipe seront bientôt disponibles.</p>
        </div>
      )}

      {chancelier && (
        <div class="equipe-featured-block">
          <PersonCard
            name={chancelier.name}
            role="Chancelier"
            roleDescription="Le chancelier du séminaire assure les contacts avec le Saint-Synode et les établissements synodaux, nomme tous les titulaires aux postes pédagogiques et administratifs, approuve la procédure d'admission des élèves, agrée les programmes des cours, surveille toutes les sphères de l'activité du séminaire, représente le séminaire auprès des autorités religieuses et civiles. Le chancelier est nommé par le Saint-Synode du patriarcat de Moscou."
            description={chancelier.description}
            photoUrl={getImageUrl(chancelier.photo, 'medium')}
            photoAlt={chancelier.name}
            featured={true}
          />
        </div>
      )}

      {recteur && (
        <div class="equipe-featured-block">
          <PersonCard
            name={recteur.name}
            role="Recteur"
            roleDescription="Nommé par le Saint-Synode de l'Église orthodoxe russe, il dirige le processus académique ainsi que la vie quotidienne du séminaire et représente celui-ci dans ses relations avec les autres établissements d'enseignement. Il est président du Conseil académique et de la commission d'examen. Dans l'exercice de ses fonctions, il agit sous le contrôle du chancelier du séminaire."
            description={recteur.description}
            photoUrl={getImageUrl(recteur.photo, 'medium')}
            photoAlt={recteur.name}
            featured={true}
          />
        </div>
      )}

      {administration.length > 0 && (
        <div class="equipe-group">
          <h2 class="equipe-group-title">Administration</h2>
          <div class="equipe-grid">
            {administration.map((person: StaffMember) => {
              const lines = (person.description || '').split('\n');
              const titleLine = lines[0] || '';
              const restLines = lines.slice(1).join('\n');
              return (
                <PersonCard
                  name={person.name}
                  role={person.role}
                  title={titleLine}
                  description={restLines}
                  photoUrl={getImageUrl(person.photo, 'small')}
                  photoAlt={person.name}
                  expandable={true}
                />
              );
            })}
          </div>
        </div>
      )}

      {anciens.length > 0 && (
        <div class="equipe-group">
          <h2 class="equipe-group-title">Anciens chanceliers et recteurs</h2>
          <div class="equipe-grid">
            {anciens.map((person: StaffMember) => {
              const lines = (person.description || '').split('\n');
              const titleLine = lines[0] || '';
              const restLines = lines.slice(1).join('\n');
              return (
                <PersonCard
                  name={person.name}
                  role={person.role}
                  title={titleLine}
                  description={restLines}
                  photoUrl={getImageUrl(person.photo, 'small')}
                  photoAlt={person.name}
                />
              );
            })}
          </div>
        </div>
      )}
    </div>
  </section>
</PageLayout>

<style>
  .equipe-section {
    padding: 3rem 0 5rem;
  }
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .equipe-placeholder {
    text-align: center;
    padding: 4rem 0;
    color: var(--muted);
    font-size: 1rem;
  }
  .equipe-featured-block {
    margin-bottom: 3rem;
  }
  .equipe-featured-block + .equipe-featured-block {
    margin-top: -1rem;
  }
  .equipe-group {
    margin-top: 3.5rem;
  }
  .equipe-group-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--fg);
    margin: 0 0 1.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--accent);
    letter-spacing: -0.01em;
  }
  .equipe-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.75rem;
  }

  @media (max-width: 768px) {
    .equipe-section { padding: 2rem 0 3rem; }
    .container { padding: 0 1.25rem; }
    .equipe-grid { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
  }
  @media (max-width: 520px) {
    .equipe-grid { grid-template-columns: 1fr; }
  }
</style>
