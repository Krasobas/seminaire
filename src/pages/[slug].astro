---
import PageLayout from '../layouts/PageLayout.astro';
import { getPage, getImageUrl } from '../lib/strapi';

const { slug } = Astro.params;
const page = await getPage(slug!);
---

{!page ? (
  <PageLayout title="Page non trouvée" hero={true}>
    <div class="not-found-content container">
      <p>Cette page n'existe pas encore. Elle sera disponible dès que le contenu sera publié dans le système de gestion.</p>
      <a href="/" class="btn btn-accent">Retour à l'accueil</a>
    </div>
  </PageLayout>
) : (
  <PageLayout title={page.title} description={page.content ? page.content.substring(0, 160) : undefined}>
    <article class="page-content container">
      {getImageUrl(page.image, 'large') ? (
        <div class="page-image">
          <img
            src={getImageUrl(page.image, 'large')!}
            alt={page.title}
            loading="lazy"
          />
        </div>
      ) : null}
      <div class="page-body" set:html={page.content} />
    </article>
  </PageLayout>
)}

<style>
  .not-found-content {
    text-align: center;
    padding: 4rem 3rem 6rem;
  }
  .not-found-content p {
    font-size: 1rem;
    color: var(--muted);
    margin-bottom: 2rem;
    line-height: 1.7;
  }
  .page-content {
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 3rem 6rem;
  }
  .page-image {
    margin-bottom: 3rem;
    border-radius: 12px;
    overflow: hidden;
  }
  .page-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
    max-height: 420px;
  }
  .page-body {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.85;
    color: var(--fg);
  }
  .page-body :global(h2) {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 500;
    margin: 2.5rem 0 1rem;
    color: var(--fg);
  }
  .page-body :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    margin: 2rem 0 0.75rem;
    color: var(--fg);
  }
  .page-body :global(p) { margin-bottom: 1.25rem; }
  .page-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .page-body :global(a:hover) { color: var(--burgundy); }
  .page-body :global(ul), .page-body :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .page-body :global(li) { margin-bottom: 0.4rem; }
  .page-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--muted);
    font-style: italic;
  }
  .page-body :global(img) { border-radius: 8px; margin: 1.5rem 0; }
  @media (max-width: 768px) {
    .not-found-content { padding: 2.5rem 1.5rem 4rem; }
    .page-content { padding: 2.5rem 1.5rem 4rem; }
  }
</style>
