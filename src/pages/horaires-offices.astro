---
import PageLayout from '../layouts/PageLayout.astro';
import { getLiturgySchedule, formatDate } from '../lib/strapi';

const schedule = await getLiturgySchedule(20);
---

<PageLayout title="Horaires des offices" overline="Vie liturgique" description="Horaires des offices et célébrations du Séminaire Orthodoxe Russe Sainte-Geneviève">
  <section class="liturgy-section container">
    <p class="liturgy-intro">
      Des offices sont célébrés chaque jour dans les églises du séminaire : la chapelle intérieure Sainte-Geneviève-et-Saint-Martin
      et l'église Notre-Dame de la Nativité. Toutes nos célébrations sont retransmises en direct sur notre chaîne YouTube.
    </p>

    <div class="youtube-link">
      <a href="https://www.youtube.com/@seminairerusse" target="_blank" rel="noopener" class="btn btn-accent">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Suivre en direct
      </a>
    </div>

    {schedule.length === 0 ? (
      <div class="empty-state">
        <p>Aucun horaire publié pour le moment.</p>
      </div>
    ) : (
      <div class="schedule-list">
        {schedule.map(item => (
          <div class="schedule-item reveal">
            <div class="schedule-date">
              <span class="schedule-day">
                {new Date(item.date).toLocaleDateString('fr-FR', {
                  weekday: 'long',
                  day: 'numeric',
                  month: 'long',
                  year: 'numeric'
                })}
              </span>
              {item.time && <span class="schedule-time">{item.time}</span>}
            </div>
            <div class="schedule-info">
              <h3 class="schedule-title">{item.title}</h3>
              {item.location && <span class="schedule-location">{item.location}</span>}
              {item.description && <p class="schedule-desc">{item.description}</p>}
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
</PageLayout>

<style>
  .liturgy-section {
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 3rem 6rem;
  }
  .liturgy-intro {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--muted);
    margin-bottom: 2rem;
    max-width: 680px;
  }
  .youtube-link {
    margin-bottom: 3rem;
  }
  .empty-state {
    text-align: center;
    padding: 4rem 0;
    color: var(--muted);
  }
  .schedule-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .schedule-item {
    display: flex;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .schedule-item:first-child {
    border-top: 1px solid var(--border);
  }
  .schedule-date {
    flex-shrink: 0;
    width: 220px;
    display: flex;
    flex-direction: column;
  }
  .schedule-day {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--fg);
    text-transform: capitalize;
  }
  .schedule-time {
    font-size: 0.82rem;
    color: var(--accent);
    font-weight: 600;
    margin-top: 0.25rem;
  }
  .schedule-info {
    flex: 1;
  }
  .schedule-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--fg);
    margin-bottom: 0.25rem;
  }
  .schedule-location {
    display: inline-block;
    font-size: 0.78rem;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }
  .schedule-desc {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.6;
  }
  @media (max-width: 768px) {
    .liturgy-section { padding: 2.5rem 1.5rem 4rem; }
    .schedule-item { flex-direction: column; gap: 0.5rem; }
    .schedule-date { width: auto; }
  }
</style>
