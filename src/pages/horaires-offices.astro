---
import PageLayout from '../layouts/PageLayout.astro';
import { getLiturgySchedule, formatDate } from '../lib/strapi';

const periods = [
  { key: '', label: 'Tous' },
  { key: 'Temps ordinaire', label: 'Temps ordinaire' },
  { key: 'Careme', label: 'Carême' },
  { key: 'Premiere semaine', label: 'Première semaine' },
  { key: 'Semaine Sainte', label: 'Semaine Sainte' },
  { key: 'Vacances', label: 'Vacances' },
];

const currentPeriod = Astro.url.searchParams.get('period') || '';
const schedule = await getLiturgySchedule(currentPeriod || undefined, 50);
---

<PageLayout title="Horaires des offices" overline="Vie liturgique" description="Horaires des offices et célébrations du Séminaire Orthodoxe Russe Sainte-Geneviève">
  <section class="liturgy-section container">
    <p class="liturgy-intro">
      Des offices sont célébrés chaque jour dans les églises du séminaire : la chapelle intérieure Sainte-Geneviève-et-Saint-Martin
      et l'église Notre-Dame de la Nativité. Toutes nos célébrations sont retransmises en direct sur notre chaîne YouTube.
    </p>

    <div class="youtube-link">
      <a href="https://www.youtube.com/@seminairerusse" target="_blank" rel="noopener" class="btn btn-accent">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Suivre en direct
      </a>
    </div>

    <div class="period-tabs">
      {periods.map(p => (
        <a
          href={p.key ? `/horaires-offices?period=${encodeURIComponent(p.key)}` : '/horaires-offices'}
          class:list={['period-tab', { active: currentPeriod === p.key }]}
        >
          {p.label}
        </a>
      ))}
    </div>

    {schedule.length === 0 ? (
      <div class="empty-state">
        <p>Aucun horaire publié pour cette période.</p>
      </div>
    ) : (
      <div class="schedule-list">
        {schedule.map(item => (
          <div class="schedule-day-card reveal">
            <h3>{item.title}</h3>
            {item.location && <p><strong>Lieu :</strong> {item.location}</p>}
            {item.time && <p><strong>Heure :</strong> {item.time}</p>}
            {item.description && <p>{item.description}</p>}
            {item.content && <div set:html={item.content} />}
          </div>
        ))}
      </div>
    )}
  </section>
</PageLayout>

<style>
  .liturgy-section {
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 3rem 6rem;
  }
  .liturgy-intro {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--muted);
    margin-bottom: 2rem;
    max-width: 680px;
  }
  .youtube-link {
    margin-bottom: 2rem;
  }
  .empty-state {
    text-align: center;
    padding: 4rem 0;
    color: var(--muted);
  }
  .schedule-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  @media (max-width: 768px) {
    .liturgy-section { padding: 2.5rem 1.5rem 4rem; }
  }
</style>
