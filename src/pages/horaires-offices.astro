---
import PageLayout from '../layouts/PageLayout.astro';

// Schedule data scraped from seminaire-orthodoxe.fr/horaires-offices
// Each period has an array of days, each day has a name and offices
const scheduleData: Record<string, { label: string; days: { name: string; offices: { time: string; office: string }[] }[]; extra?: string }> = {
  'ordinaires': {
    label: 'Horaires ordinaires',
    days: [
      { name: 'Lundi', offices: [{ time: '19 h', office: 'Vêpres' }] },
      { name: 'Mardi', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres' }] },
      { name: 'Mercredi', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres' }] },
      { name: 'Jeudi', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres' }] },
      { name: 'Vendredi', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres' }] },
      { name: 'Samedi', offices: [{ time: '9 h', office: 'Divine liturgie' }, { time: '18 h', office: 'Grandes vêpres' }] },
      { name: 'Dimanche', offices: [{ time: '9 h', office: 'Matines' }, { time: '10 h', office: 'Divine liturgie' }] },
    ],
  },
  'premiiere-semaine': {
    label: 'Première semaine du carême',
    days: [
      { name: 'Lundi', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres' }, { time: '21 h', office: 'Grandes Complies avec le Canon pénitentiel de saint André de Crête' }] },
      { name: 'Mardi', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres' }, { time: '21 h', office: 'Grandes Complies avec le Canon pénitentiel de saint André de Crête' }] },
      { name: 'Mercredi', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres avec la liturgie des Dons présanctifiés' }, { time: '21 h', office: 'Grandes Complies avec le Canon pénitentiel de saint André de Crête' }] },
      { name: 'Jeudi', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres' }, { time: '21 h', office: 'Grandes Complies avec le Canon pénitentiel de saint André de Crête' }] },
      { name: 'Vendredi', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres avec la liturgie des Dons présanctifiés' }] },
      { name: 'Samedi', offices: [{ time: '9 h', office: 'Divine liturgie' }, { time: '18 h', office: 'Grandes vêpres' }] },
      { name: 'Dimanche', offices: [{ time: '9 h', office: 'Matines' }, { time: '10 h', office: 'Divine liturgie' }] },
    ],
  },
  'grand-careme': {
    label: 'Grand carême',
    days: [
      { name: 'Lundi', offices: [{ time: '19 h', office: 'Vêpres' }] },
      { name: 'Mardi', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres' }] },
      { name: 'Mercredi', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres avec la liturgie des Dons présanctifiés' }] },
      { name: 'Jeudi', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres' }] },
      { name: 'Vendredi', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres avec la liturgie des Dons présanctifiés' }] },
      { name: 'Samedi', offices: [{ time: '9 h', office: 'Divine liturgie' }, { time: '18 h', office: 'Grandes vêpres' }] },
      { name: 'Dimanche', offices: [{ time: '9 h', office: 'Matines' }, { time: '10 h', office: 'Divine liturgie' }] },
    ],
  },
  'semaine-sainte': {
    label: 'Semaine Sainte et Pâques',
    days: [
      { name: 'Lundi Saint', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres avec la liturgie des Dons présanctifiés' }] },
      { name: 'Mardi Saint', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres avec la liturgie des Dons présanctifiés' }] },
      { name: 'Mercredi Saint', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '19 h', office: 'Vêpres avec la liturgie des Dons présanctifiés' }] },
      { name: 'Jeudi Saint', offices: [{ time: '7 h 30', office: 'Matines' }, { time: '18 h', office: 'Vêpres avec la liturgie de la Cène' }] },
      { name: 'Vendredi Saint', offices: [{ time: '7 h 30', office: 'Matines avec lecture des douze péricopes de la Passion' }, { time: '12 h', office: 'Heures royales : Tierce et Sexte' }, { time: '18 h', office: "Vêpres avec la procession de l'Épitaphios" }] },
      { name: 'Samedi Saint', offices: [{ time: '9 h', office: "Matines avec la vénération de l'Épitaphios" }, { time: '16 h 30', office: 'Vêpres avec la première liturgie pascale' }, { time: '23 h 30', office: 'Office de minuit' }] },
      { name: 'Pâques (nuit)', offices: [{ time: '0 h', office: 'Procession et matines de Pâques' }, { time: '1 h', office: 'Divine liturgie' }] },
      { name: 'Pâques (jour)', offices: [{ time: '18 h', office: 'Grandes Vêpres' }] },
    ],
  },
  'vacances': {
    label: 'Vacances',
    days: [],
    extra: `<p>Durant les vacances, les célébrations suivantes ont lieu :</p>
<ul>
  <li><strong>le dimanche à 10 h</strong> — Divine liturgie</li>
  <li><strong>le samedi à 18 h</strong> — Grandes vêpres (hors vacances d'été)</li>
</ul>
<h3>Vacances de la Toussaint</h3>
<p>du soir du dimanche 26 octobre 2025 au samedi 1er novembre 2025</p>
<h3>Vacances de Noël</h3>
<p>du vendredi 26 décembre 2025 au vendredi 2 janvier 2026</p>
<h3>Vacances d'hiver</h3>
<p>du soir du dimanche 1er mars 2026 au samedi 7 mars 2026</p>
<h3>Vacances de printemps</h3>
<p>du soir du dimanche 27 avril 2026 au samedi 2 mai 2026</p>
<h3>Vacances d'été</h3>
<p>du lundi 29 juin 2026 au vendredi 18 septembre 2026</p>
<p>Pendant les vacances d'été, hormis la Divine liturgie dominicale, les célébrations suivantes ont lieu :</p>
<ul>
  <li><strong>Transfiguration de notre Seigneur Jésus Christ</strong> (6 août) — 10 h, Divine liturgie</li>
  <li><strong>Dormition de la Mère de Dieu</strong> (15 août) — 10 h, Divine liturgie</li>
  <li><strong>Nativité de la Mère de Dieu</strong> (8 septembre) — 10 h, Divine liturgie</li>
</ul>`,
  },
};

const periods = Object.entries(scheduleData);
const defaultPeriod = 'ordinaires';
---

<PageLayout title="Horaires des offices" overline="Vie liturgique" description="Horaires des célébrations liturgiques du Séminaire Orthodoxe Russe Sainte-Geneviève">
  <section class="schedule-section container">
    <div class="period-tabs" id="period-tabs">
      {periods.map(([key, period]) => (
        <button
          class:list={['period-tab', { active: key === defaultPeriod }]}
          data-period={key}
        >
          {period.label}
        </button>
      ))}
    </div>

    {periods.map(([key, period]) => (
      <div class:list={['period-content', { active: key === defaultPeriod }]} data-period-content={key}>
        {period.extra ? (
          <div class="schedule-extra" set:html={period.extra} />
        ) : (
          <div class="schedule-days">
            {period.days.map(day => (
              <div class="schedule-day-card">
                <h3>{day.name}</h3>
                <div class="schedule-offices">
                  {day.offices.map(office => (
                    <div class="schedule-office">
                      <span class="schedule-time">{office.time}</span>
                      <span class="schedule-name">{office.office}</span>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    ))}

    <div class="schedule-contact reveal">
      <h3>Accueil pastoral et accompagnement spirituel</h3>
      <p>Pour la célébration des baptêmes, des offices à la mémoire des défunts ainsi que pour les autres sacrements ou en cas d'urgence pastorale, vous pouvez contacter le P. Pierre Smirnov :</p>
      <p class="schedule-contact-info">
        <a href="mailto:secretariat@seminaria.fr">secretariat@seminaria.fr</a>
      </p>
      <h3>Entretien spirituel / Confession</h3>
      <p>Si vous souhaitez voir le prêtre en vue d'un entretien spirituel et/ou d'une confession, vous pouvez prendre un rendez-vous avec le P. François Esperet :</p>
      <p class="schedule-contact-info">
        <a href="mailto:francois.esperet@wanadoo.fr">francois.esperet@wanadoo.fr</a>
      </p>
    </div>
  </section>
</PageLayout>

<script>
  const tabs = document.querySelectorAll('.period-tab');
  const contents = document.querySelectorAll('.period-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const period = (tab as HTMLElement).dataset.period;
      tabs.forEach(t => t.classList.remove('active'));
      contents.forEach(c => c.classList.remove('active'));
      tab.classList.add('active');
      document.querySelector(`[data-period-content="${period}"]`)?.classList.add('active');
    });
  });
</script>

<style>
  .schedule-section {
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 3rem 6rem;
  }

  /* Period tabs */
  .period-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 2.5rem;
    border-bottom: 2px solid var(--border);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .period-tab {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--muted);
    background: none;
    border: none;
    padding: 0.75rem 1.25rem;
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: all 0.2s ease;
  }
  .period-tab:hover {
    color: var(--fg);
  }
  .period-tab.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* Period content */
  .period-content {
    display: none;
  }
  .period-content.active {
    display: block;
  }

  /* Schedule days grid */
  .schedule-days {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .schedule-day-card {
    padding: 1.25rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: box-shadow 0.3s ease;
  }
  .schedule-day-card:hover {
    box-shadow: var(--shadow-hover);
  }
  .schedule-day-card h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--fg);
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .schedule-offices {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .schedule-office {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
  }
  .schedule-time {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    white-space: nowrap;
    min-width: 4.5rem;
  }
  .schedule-name {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.5;
  }

  /* Vacances extra content */
  .schedule-extra {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--fg);
  }
  .schedule-extra :global(h3) {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    margin: 1.5rem 0 0.5rem;
    color: var(--fg);
  }
  .schedule-extra :global(p) {
    margin-bottom: 0.75rem;
    color: var(--muted);
  }
  .schedule-extra :global(ul) {
    margin: 0.75rem 0;
    padding-left: 1.25rem;
  }
  .schedule-extra :global(li) {
    margin-bottom: 0.5rem;
    color: var(--muted);
    line-height: 1.6;
  }
  .schedule-extra :global(li strong) {
    color: var(--fg);
  }

  /* Contact section */
  .schedule-contact {
    margin-top: 3rem;
    padding: 2rem;
    background: var(--bg-alt);
    border-radius: 12px;
    border: 1px solid var(--border);
  }
  .schedule-contact h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--fg);
    margin-bottom: 0.5rem;
  }
  .schedule-contact h3:not(:first-child) {
    margin-top: 1.5rem;
  }
  .schedule-contact p {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 0.5rem;
  }
  .schedule-contact-info a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }
  .schedule-contact-info a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .schedule-section { padding: 2.5rem 1.5rem 4rem; }
    .schedule-days { grid-template-columns: 1fr; }
    .period-tabs { gap: 0; }
    .period-tab { font-size: 0.78rem; padding: 0.6rem 0.75rem; }
  }
</style>
