---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="404 — Page non trouvée | Séminaire Orthodoxe Sainte-Geneviève">
  <style>
    .not-found {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
      background: var(--bg);
      transition: background 0.4s ease;
    }

    .not-found-logo {
      width: 48px;
      height: auto;
      opacity: 0.35;
      margin-bottom: 3rem;
    }

    .not-found-code {
      font-family: var(--font-display);
      font-size: 5rem;
      font-weight: 400;
      color: var(--accent);
      line-height: 1;
      margin-bottom: 0.75rem;
    }

    .not-found-title {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 500;
      color: var(--fg);
      margin-bottom: 0.5rem;
    }

    .not-found-text {
      font-family: var(--font-body);
      font-size: 0.9rem;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 2.5rem;
    }

    .not-found-home {
      font-family: var(--font-body);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: #fff;
      background: var(--accent);
      padding: 0.6rem 1.8rem;
      border-radius: 100px;
      text-decoration: none;
      transition: all 0.25s ease;
    }

    .not-found-home:hover {
      background: var(--burgundy);
      transform: translateY(-1px);
    }
  </style>

  <div class="not-found">
    <img src="/logo.svg" alt="" class="not-found-logo" />
    <div class="not-found-code">404</div>
    <h1 class="not-found-title">Page non trouvée</h1>
    <p class="not-found-text">La page que vous cherchez n'existe pas ou a été déplacée.</p>
    <a href="/" class="not-found-home">Retour à l'accueil</a>
  </div>
</BaseLayout>
