---
import PageLayout from '../../layouts/PageLayout.astro';
import { getAllEpisodes, formatDate } from '../../lib/strapi';
import type { Episode } from '../../lib/strapi';

const PLAYLIST_ID = 'PLGG6Bdu_97TvOy4DUz_WETUuQbBejvfeu';
const PLAYLIST_URL = `https://youtube.com/playlist?list=${PLAYLIST_ID}`;

// Known video IDs from the "Questions du cœur" playlist
const PLAYLIST_VIDEO_IDS = new Set([
  'N3fR6ZmzM8Y', // TEASER
  '27hiUCTL63Q', // SALUT
  '44DcNwlNT5Y', // L'Homme selon la Bible
  'uDdjQ8LPS9Y', // L'Évangile
  'PtoFfIAPPyc', // LA FOI
  'wKnTyiiv5sc', // Les différentes religions
  'HNLB76oL42c', // PÂQUES
  'IDfu7GOmpok', // ÊTRE BON NE SUFFIT PAS
  'bj7RNXVMswU', // Pourquoi la théologie
]);

function extractYoutubeId(url: string): string | null {
  if (!url) return null;
  const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]{11})/);
  return match ? match[1] : null;
}

// Fetch all episodes and filter to only the playlist ones
const result = await getAllEpisodes(1, 100);
const allEpisodes = result?.data || [];
const episodes = allEpisodes.filter((ep: Episode) => {
  const ytId = extractYoutubeId(ep.youtubeUrl);
  return ytId && PLAYLIST_VIDEO_IDS.has(ytId);
});

// Sort: TEASER last, newest first (by episode order, not import date)
// Use YouTube video order from playlist
const PLAYLIST_ORDER = [
  'bj7RNXVMswU', // Pourquoi la théologie
  'IDfu7GOmpok', // ÊTRE BON NE SUFFIT PAS
  'HNLB76oL42c', // PÂQUES
  'wKnTyiiv5sc', // Les différentes religions
  'PtoFfIAPPyc', // LA FOI
  'uDdjQ8LPS9Y', // L'Évangile
  '44DcNwlNT5Y', // L'Homme selon la Bible
  '27hiUCTL63Q', // LE SALUT
  'N3fR6ZmzM8Y', // TEASER
];

episodes.sort((a: Episode, b: Episode) => {
  const idA = extractYoutubeId(a.youtubeUrl) || '';
  const idB = extractYoutubeId(b.youtubeUrl) || '';
  return PLAYLIST_ORDER.indexOf(idA) - PLAYLIST_ORDER.indexOf(idB);
});

const latestEpisode = episodes[0];
const restEpisodes = episodes.slice(1);
---

<PageLayout title="Questions du cœur" overline="Émission" description="Émission hebdomadaire consacrée à la découverte et à l'approfondissement de la foi chrétienne orthodoxe">
  <section class="episodes-section container">
    <p class="episodes-intro">
      Une émission hebdomadaire consacrée à la découverte et à l'approfondissement de la foi chrétienne orthodoxe,
      à travers des questions existentielles autant que des thèmes fondamentaux du catéchisme.
    </p>

    {episodes.length === 0 ? (
      <div class="emission-empty">
        <img src="/logo.svg" data-logo alt="" class="emission-empty-logo" />
        <p>Les épisodes seront bientôt disponibles.</p>
        <a href={PLAYLIST_URL} target="_blank" rel="noopener" class="btn btn-accent">
          Découvrir sur YouTube →
        </a>
      </div>
    ) : (
      <div class="emission-grid">
        {latestEpisode && (() => {
          const ytId = extractYoutubeId(latestEpisode.youtubeUrl);
          return (
            <a href={latestEpisode.youtubeUrl} class="emission-hero-card reveal" target="_blank" rel="noopener">
              <div class="emission-hero-thumb">
                {ytId ? (
                  <img
                    src={`https://img.youtube.com/vi/${ytId}/hqdefault.jpg`}
                    alt={latestEpisode.title}
                    loading="lazy"
                    onerror={`this.onerror=null;this.src='/logo.svg';this.style.objectFit='contain';this.style.padding='2rem';this.style.opacity='0.15';`}
                  />
                ) : (
                  <img src="/logo.svg" data-logo alt="" class="emission-fallback-logo" />
                )}
                <div class="emission-play-overlay">
                  <svg width="56" height="56" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
              <div class="emission-hero-info">
                <span class="emission-hero-label">Dernier épisode</span>
                <h3>{latestEpisode.title}</h3>
              </div>
            </a>
          );
        })()}

        {restEpisodes.length > 0 && (
          <div class="emission-list">
            {restEpisodes.map((ep: Episode) => {
              const ytId = extractYoutubeId(ep.youtubeUrl);
              return (
                <a href={ep.youtubeUrl} class="emission-list-card reveal" target="_blank" rel="noopener">
                  <div class="emission-list-thumb">
                    {ytId ? (
                      <img
                        src={`https://img.youtube.com/vi/${ytId}/mqdefault.jpg`}
                        alt={ep.title}
                        loading="lazy"
                        onerror={`this.onerror=null;this.src='/logo.svg';this.style.objectFit='contain';this.style.padding='0.5rem';this.style.opacity='0.15';`}
                      />
                    ) : (
                      <img src="/logo.svg" data-logo alt="" class="emission-fallback-logo-sm" />
                    )}
                    <div class="emission-list-play">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
                    </div>
                  </div>
                  <div class="emission-list-info">
                    <h4>{ep.title}</h4>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
    )}

    <div class="emission-playlist-btn reveal">
      <a href={PLAYLIST_URL} target="_blank" rel="noopener" class="btn btn-dark">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Toute la playlist YouTube →
      </a>
    </div>
  </section>
</PageLayout>

<style>
  .episodes-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 3rem 6rem;
  }
  .episodes-intro {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--muted);
    margin-bottom: 3rem;
    max-width: 680px;
  }

  /* Empty state */
  .emission-empty {
    text-align: center;
    padding: 3rem 0;
  }
  .emission-empty-logo {
    width: 64px;
    height: auto;
    opacity: 0.12;
    margin-bottom: 1.5rem;
  }
  .emission-empty p {
    font-size: 1rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  /* Grid: hero + list */
  .emission-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
  }

  /* Hero card */
  .emission-hero-card {
    display: flex;
    flex-direction: column;
    background: var(--card);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .emission-hero-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
  }
  .emission-hero-thumb {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--bg-alt);
  }
  .emission-hero-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .emission-hero-card:hover .emission-hero-thumb img {
    transform: scale(1.05);
  }
  .emission-fallback-logo {
    width: 64px;
    height: auto;
    opacity: 0.12;
    margin: auto;
  }
  .emission-play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.25);
    transition: background 0.3s ease;
  }
  .emission-hero-card:hover .emission-play-overlay {
    background: rgba(0,0,0,0.4);
  }
  .emission-play-overlay svg {
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.4));
    transition: transform 0.3s ease;
  }
  .emission-hero-card:hover .emission-play-overlay svg {
    transform: scale(1.1);
  }
  .emission-hero-info {
    padding: 1.5rem;
  }
  .emission-hero-label {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
  .emission-hero-info h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    margin: 0.75rem 0 0;
    line-height: 1.35;
  }

  /* List cards */
  .emission-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .emission-list-card {
    display: flex;
    gap: 1rem;
    align-items: center;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .emission-list-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
  }
  .emission-list-thumb {
    position: relative;
    width: 140px;
    min-width: 140px;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--bg-alt);
  }
  .emission-list-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .emission-fallback-logo-sm {
    width: 32px;
    height: auto;
    opacity: 0.12;
    margin: auto;
  }
  .emission-list-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.2);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .emission-list-card:hover .emission-list-play {
    opacity: 1;
  }
  .emission-list-info {
    padding: 0.75rem 0.75rem 0.75rem 0;
    flex: 1;
  }
  .emission-list-info h4 {
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 500;
    margin-bottom: 0.3rem;
    line-height: 1.35;
  }

  /* Playlist button */
  .emission-playlist-btn {
    text-align: center;
    margin-top: 2.5rem;
  }

  @media (max-width: 768px) {
    .episodes-section { padding: 2.5rem 1.5rem 4rem; }
    .emission-grid { grid-template-columns: 1fr; }
    .emission-list-thumb { width: 110px; min-width: 110px; }
  }
</style>
