---
const navItems = [
  {
    label: 'Le Séminaire',
    href: null,
    children: [
      { label: 'Histoire et mission', href: '/histoire-mission' },
      { label: 'Équipe', href: '/equipe' },
      { label: 'Séminaristes', href: '/seminaristes' },
      { label: 'Alumni', href: '/alumni' },
    ]
  },
  {
    label: 'Formation',
    href: null,
    children: [
      { label: 'Devenir séminariste', href: '/devenir-seminariste' },
      { label: 'Parcours interne', href: '/parcours-interne' },
      { label: 'Parcours à distance', href: '/parcours-distance' },
    ]
  },
  {
    label: 'Vie liturgique',
    href: null,
    children: [
      { label: 'Horaires des offices', href: '/horaires-offices' },
      { label: 'En direct', href: 'https://www.youtube.com/@seminairerusse', external: true },
    ]
  },
  { label: 'Actualités', href: '/actualites', children: null },
  { label: 'Émission', href: '/emission', children: null },
  { label: 'Visiter', href: '/visiter', children: null },
  { label: 'Contact', href: '/contact', children: null },
];
---

<nav>
  <a href="/" class="nav-logo">
    <img src="/logo.svg" alt="Séminaire Orthodoxe Sainte-Geneviève" width="56" height="68" />
    <span class="nav-logo-text">Sainte-Geneviève</span>
  </a>
  <div class="nav-center">
    {navItems.map(item => item.children ? (
      <div class="nav-dropdown">
        <button class="nav-dropdown-toggle">
          {item.label}
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4l3 3 3-3"/></svg>
        </button>
        <div class="nav-dropdown-menu">
          {item.children.map(child => (
            <a href={child.href} {...(child.external ? { target: '_blank', rel: 'noopener' } : {})}>
              {child.label}
            </a>
          ))}
        </div>
      </div>
    ) : (
      <a href={item.href!}>{item.label}</a>
    ))}
  </div>
  <div class="nav-right">
    <button class="theme-toggle" onclick="toggleTheme()" title="Changer le thème" aria-label="Changer le thème">
      <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/>
        <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
      </svg>
      <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
    <a href="/faire-don" class="nav-cta">Faire un don</a>
  </div>
  <button class="nav-mobile-toggle" aria-label="Menu" onclick="document.querySelector('.nav-mobile').classList.toggle('open')">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
  </button>
</nav>

<!-- Mobile menu -->
<div class="nav-mobile">
  {navItems.map(item => item.children ? (
    <div class="nav-mobile-group">
      <button class="nav-mobile-group-toggle" onclick="this.parentElement.classList.toggle('expanded')">
        {item.label}
        <svg width="12" height="12" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4l3 3 3-3"/></svg>
      </button>
      <div class="nav-mobile-group-items">
        {item.children.map(child => (
          <a href={child.href} {...(child.external ? { target: '_blank', rel: 'noopener' } : {})}>{child.label}</a>
        ))}
      </div>
    </div>
  ) : (
    <a href={item.href!}>{item.label}</a>
  ))}
  <a href="/faire-don" class="nav-mobile-cta">Faire un don</a>
</div>

<style>
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: 72px;
    display: flex; justify-content: space-between; align-items: center; padding: 0 4rem;
    background: var(--nav-bg); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border);
    transition: background 0.4s ease;
  }
  .nav-logo {
    display: flex; align-items: center; gap: 0.75rem;
    text-decoration: none; color: var(--fg);
    margin-bottom: -18px; position: relative; z-index: 101;
  }
  .nav-logo img { height: 90px; width: auto; filter: var(--logo-filter, none); }
  .nav-logo-text {
    font-family: var(--font-display); font-size: 1.05rem; font-weight: 500;
    align-self: center; margin-top: -8px;
  }

  .nav-center { display: flex; gap: 0; align-items: center; }
  .nav-center > a {
    font-family: var(--font-body); font-size: 0.8rem; font-weight: 500; color: var(--muted);
    text-decoration: none; letter-spacing: 0.04em; transition: color 0.2s ease; position: relative;
    padding: 0.5rem 1rem;
  }
  .nav-center > a:hover { color: var(--fg); }
  .nav-center > a::after {
    content: ''; position: absolute; bottom: -2px; left: 1rem; right: 1rem; height: 1.5px;
    background: var(--accent); transition: opacity 0.25s ease; opacity: 0;
  }
  .nav-center > a:hover::after { opacity: 1; }

  /* Dropdown */
  .nav-dropdown { position: relative; }
  .nav-dropdown-toggle {
    font-family: var(--font-body); font-size: 0.8rem; font-weight: 500; color: var(--muted);
    background: none; border: none; cursor: pointer; padding: 0.5rem 1rem;
    display: flex; align-items: center; gap: 0.35rem; letter-spacing: 0.04em;
    transition: color 0.2s ease;
  }
  .nav-dropdown-toggle:hover { color: var(--fg); }
  .nav-dropdown-toggle svg { transition: transform 0.2s ease; }
  .nav-dropdown:hover .nav-dropdown-toggle svg { transform: rotate(180deg); }

  .nav-dropdown-menu {
    position: absolute; top: 100%; left: 0; min-width: 200px;
    background: var(--card); border: 1px solid var(--border); border-radius: 10px;
    padding: 0.5rem 0; box-shadow: var(--shadow-hover);
    opacity: 0; visibility: hidden; transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    z-index: 200;
  }
  .nav-dropdown:hover .nav-dropdown-menu {
    opacity: 1; visibility: visible; transform: translateY(0);
  }
  .nav-dropdown-menu a {
    display: block; padding: 0.55rem 1.25rem; font-family: var(--font-body);
    font-size: 0.8rem; color: var(--muted); text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }
  .nav-dropdown-menu a:hover {
    color: var(--fg); background: var(--accent-soft);
  }

  .nav-right { display: flex; align-items: center; gap: 1.5rem; }

  /* Theme toggle — light/dark only */
  .theme-toggle {
    background: none; border: none; cursor: pointer; color: var(--muted);
    padding: 0.4rem; border-radius: 8px; transition: color 0.2s, background 0.2s;
    display: flex; align-items: center; justify-content: center;
  }
  .theme-toggle:hover { color: var(--accent); background: var(--accent-soft); }
  .icon-sun { display: none; }
  .icon-moon { display: block; }

  :global([data-theme="light"]) .icon-sun { display: none; }
  :global([data-theme="light"]) .icon-moon { display: block; }
  :global([data-theme="dark"]) .icon-sun { display: block; }
  :global([data-theme="dark"]) .icon-moon { display: none; }
  /* For seasonal themes (lent, pascha, christmas) — show moon icon to switch to dark */
  :global([data-theme="lent"]) .icon-sun { display: none; }
  :global([data-theme="lent"]) .icon-moon { display: block; }
  :global([data-theme="pascha"]) .icon-sun { display: none; }
  :global([data-theme="pascha"]) .icon-moon { display: block; }
  :global([data-theme="christmas"]) .icon-sun { display: none; }
  :global([data-theme="christmas"]) .icon-moon { display: block; }

  .nav-cta {
    font-family: var(--font-body); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.04em;
    color: #fff; background: var(--accent); padding: 0.5rem 1.3rem; border-radius: 100px;
    text-decoration: none; transition: all 0.25s ease;
  }
  .nav-cta:hover { background: var(--burgundy); transform: translateY(-1px); }

  /* Mobile toggle */
  .nav-mobile-toggle { display: none; background: none; border: none; cursor: pointer; color: var(--fg); }

  /* Mobile menu */
  .nav-mobile {
    display: none; position: fixed; top: 72px; left: 0; right: 0; bottom: 0;
    background: var(--nav-bg); backdrop-filter: blur(20px);
    padding: 2rem; overflow-y: auto; z-index: 99;
  }
  .nav-mobile.open { display: block; }
  .nav-mobile > a {
    display: block; padding: 0.9rem 0; font-family: var(--font-body);
    font-size: 1rem; font-weight: 500; color: var(--fg); text-decoration: none;
    border-bottom: 1px solid var(--border);
  }
  .nav-mobile-group-toggle {
    display: flex; justify-content: space-between; align-items: center; width: 100%;
    padding: 0.9rem 0; font-family: var(--font-body); font-size: 1rem; font-weight: 500;
    color: var(--fg); background: none; border: none; border-bottom: 1px solid var(--border);
    cursor: pointer;
  }
  .nav-mobile-group-toggle svg { transition: transform 0.2s ease; }
  .nav-mobile-group.expanded .nav-mobile-group-toggle svg { transform: rotate(180deg); }
  .nav-mobile-group-items {
    max-height: 0; overflow: hidden; transition: max-height 0.3s ease;
  }
  .nav-mobile-group.expanded .nav-mobile-group-items { max-height: 300px; }
  .nav-mobile-group-items a {
    display: block; padding: 0.6rem 0 0.6rem 1.25rem; font-family: var(--font-body);
    font-size: 0.9rem; color: var(--muted); text-decoration: none;
  }
  .nav-mobile-group-items a:hover { color: var(--accent); }
  .nav-mobile-cta {
    display: block; margin-top: 1.5rem; text-align: center; font-family: var(--font-body);
    font-size: 0.85rem; font-weight: 600; color: #fff; background: var(--accent);
    padding: 0.75rem 1.5rem; border-radius: 100px; text-decoration: none;
  }

  @media (max-width: 900px) {
    nav { padding: 0 1.5rem; }
    .nav-center { display: none; }
    .nav-right .theme-toggle { display: none; }
    .nav-right .nav-cta { display: none; }
    .nav-mobile-toggle { display: flex; }
  }
</style>

<script is:inline>
  function toggleTheme() {
    var current = document.documentElement.getAttribute('data-theme') || 'light';
    var userThemes = ['light', 'dark'];
    // If current is a seasonal theme or dark, switch to light; if light, switch to dark
    var next = (current === 'light') ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  }
</script>
