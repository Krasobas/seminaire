---
import { getFeaturedArticle, getNews } from '../lib/strapi';

const featured = await getFeaturedArticle();
const articles = await getNews(5);
---

<section id="actualites" class="news-section">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-overline">Actualités</p>
      <h2 class="section-title">Vie du <em>séminaire</em></h2>
    </div>

    <div class="news-grid reveal">
      {featured && (
        <a href={`/actualites/${featured.slug}`} class="news-featured">
          <div class="news-featured-tag">{featured.category?.name || 'Actualité'}</div>
          <h3>{featured.title}</h3>
          <p>{featured.excerpt}</p>
          <span class="news-date">{new Date(featured.publishedAt).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
        </a>
      )}

      <div class="news-list">
        {articles?.filter(a => a.id !== featured?.id).map(item => (
          <a href={`/actualites/${item.slug}`} class="news-item">
            <span class="news-item-tag">{item.category?.name || 'Actualité'}</span>
            <h4>{item.title}</h4>
            <span class="news-date">{new Date(item.publishedAt).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="news-more reveal">
      <a href="/actualites" class="btn btn-light">Toutes les actualités →</a>
    </div>
  </div>
</section>

<style>
  .news-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 3rem; }
  .news-featured { display: block; background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 2.5rem; text-decoration: none; transition: all 0.3s ease; }
  .news-featured:hover { box-shadow: var(--shadow-hover); transform: translateY(-3px); }
  .news-featured-tag { display: inline-block; font-size: 0.68rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); background: var(--accent-soft); padding: 0.3rem 0.8rem; border-radius: 100px; margin-bottom: 1.2rem; }
  .news-featured h3 { font-family: var(--font-display); font-size: 1.5rem; font-weight: 500; line-height: 1.3; margin-bottom: 1rem; }
  .news-featured p { font-size: 0.95rem; line-height: 1.7; color: var(--muted); margin-bottom: 1.5rem; }
  .news-date { font-size: 0.75rem; color: var(--muted); }
  .news-list { display: flex; flex-direction: column; }
  .news-item { display: block; padding: 1.25rem 0; border-bottom: 1px solid var(--border); text-decoration: none; transition: all 0.2s ease; }
  .news-item:first-child { padding-top: 0; }
  .news-item:hover { padding-left: 0.75rem; }
  .news-item-tag { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.3rem; display: block; }
  .news-item h4 { font-family: var(--font-display); font-size: 1rem; font-weight: 500; margin-bottom: 0.3rem; }
  .news-more { text-align: center; margin-top: 3rem; }
  @media (max-width: 768px) { .news-grid { grid-template-columns: 1fr; gap: 2rem; } }
</style>
