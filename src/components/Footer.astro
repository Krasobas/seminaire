---
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="footer-inner container">
    <div class="footer-brand">
      <img src="/logo.svg" alt="Logo" width="40" height="49" />
      <span class="footer-name">Séminaire Orthodoxe Sainte-Geneviève</span>
    </div>
    <div class="footer-columns">
      <div class="footer-col">
        <h4>Le Séminaire</h4>
        <a href="/histoire-mission">Histoire et mission</a>
        <a href="/equipe">Équipe</a>
        <a href="/seminaristes">Séminaristes</a>
        <a href="/alumni">Alumni</a>
      </div>
      <div class="footer-col">
        <h4>Formation</h4>
        <a href="/devenir-seminariste">Devenir séminariste</a>
        <a href="/parcours-interne">Parcours interne</a>
        <a href="/parcours-distance">Parcours à distance</a>
        <a href="/admissions">Admissions</a>
      </div>
      <div class="footer-col">
        <h4>Vie liturgique</h4>
        <a href="/horaires-offices">Horaires des offices</a>
        <a href="https://www.youtube.com/@seminairerusse" target="_blank" rel="noopener">En direct</a>
        <a href="/actualites">Actualités</a>
        <a href="/emission">Émission</a>
      </div>
      <div class="footer-col">
        <h4>Contact</h4>
        <p>4, rue Sainte-Geneviève</p>
        <p>91860 Épinay-sous-Sénart</p>
        <p>09 66 84 04 87</p>
        <a href="/contact">Nous écrire</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {currentYear} Séminaire Orthodoxe Russe Sainte-Geneviève</p>
      <div class="footer-links">
        <a href="/mentions-legales">Mentions légales</a>
        <a href="https://www.youtube.com/@seminairerusse" target="_blank" rel="noopener">YouTube</a>
        <a href="https://www.instagram.com/seminairesaintegenevieve" target="_blank" rel="noopener">Instagram</a>
        <a href="https://www.facebook.com/seminairerusse" target="_blank" rel="noopener">Facebook</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer { background: var(--bg-alt); border-top: 1px solid var(--border); padding: 4rem 0 2rem; transition: background 0.4s ease; }
  .footer-inner { max-width: 1200px; margin: 0 auto; padding: 0 3rem; }
  .footer-brand { display: flex; align-items: center; gap: 1rem; margin-bottom: 3rem; }
  .footer-brand img { width: 40px; height: auto; opacity: 0.6; filter: var(--logo-filter, none); }
  .footer-name { font-family: var(--font-display); font-size: 1.1rem; font-weight: 500; }
  .footer-columns { display: grid; grid-template-columns: repeat(4, 1fr); gap: 3rem; margin-bottom: 3rem; }
  .footer-col h4 { font-family: var(--font-display); font-size: 0.95rem; font-weight: 500; margin-bottom: 1rem; }
  .footer-col a, .footer-col p { display: block; font-size: 0.85rem; color: var(--muted); text-decoration: none; margin-bottom: 0.5rem; transition: color 0.2s; }
  .footer-col a:hover { color: var(--accent); }
  .footer-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 2rem; border-top: 1px solid var(--border); }
  .footer-bottom p { font-size: 0.78rem; color: var(--muted); }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a { font-size: 0.78rem; color: var(--muted); text-decoration: none; transition: color 0.2s; }
  .footer-links a:hover { color: var(--accent); }
  @media (max-width: 768px) {
    .footer-inner { padding: 0 1.5rem; }
    .footer-columns { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
    .footer-bottom { flex-direction: column; gap: 1rem; text-align: center; }
  }
  @media (max-width: 480px) {
    .footer-columns { grid-template-columns: 1fr; }
  }
</style>
