---
import { getEpisodes, formatDate, getImageUrl } from '../lib/strapi';

const episodes = await getEpisodes(5);
const latestEpisode = episodes?.[0];
const youtubeId = latestEpisode?.youtubeUrl
  ? (latestEpisode.youtubeUrl.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]{11})/)?.[1] || null)
  : null;
---

<section id="emission" class="emission-section">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-overline">Émission</p>
      <h2 class="section-title">Questions <em>du cœur</em></h2>
    </div>

    <div class="emission-grid reveal">
      <div class="emission-hero">
        <div class="emission-video">
          {youtubeId ? (
            <div class="video-embed" style="aspect-ratio: 16/9;">
              <iframe
                src={`https://www.youtube.com/embed/${youtubeId}`}
                title={latestEpisode?.title || 'Questions du cœur'}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
          ) : latestEpisode?.thumbnail ? (
            <a href={latestEpisode.youtubeUrl || '#'} target="_blank" rel="noopener" class="video-thumbnail-link">
              <img src={getImageUrl(latestEpisode.thumbnail, 'medium')!} alt={latestEpisode.title} />
              <div class="video-play-overlay">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </a>
          ) : (
            <div class="video-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor" opacity="0.3"><path d="M8 5v14l11-7z"/></svg>
            </div>
          )}
        </div>
        <div class="emission-cta">
          <a href="https://www.youtube.com/@seminaireorthodoxe" target="_blank" rel="noopener" class="btn btn-dark">Voir sur YouTube →</a>
        </div>
      </div>

      <div class="episodes">
        {episodes?.length > 0 ? (
          episodes.map((ep, i) => (
            <a href={ep.youtubeUrl || '#'} class="episode-item" target="_blank" rel="noopener">
              <span class="episode-num">#{episodes.length - i}</span>
              <div class="episode-info">
                <h4>{ep.title}</h4>
                <span class="episode-date">{formatDate(ep.publishedAt, 'month-year')}</span>
              </div>
              <svg class="episode-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          ))
        ) : (
          <div class="episodes-placeholder">
            <p>Les épisodes seront bientôt disponibles.</p>
            <a href="https://www.youtube.com/@seminaireorthodoxe" target="_blank" rel="noopener" class="btn btn-light">Découvrir sur YouTube →</a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .emission-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 3rem; }
  .emission-hero { display: flex; flex-direction: column; gap: 1.5rem; }
  .emission-video { border-radius: 16px; overflow: hidden; background: var(--card); border: 1px solid var(--border); }
  .video-embed { position: relative; width: 100%; }
  .video-embed iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0; }
  .video-thumbnail-link { display: block; position: relative; aspect-ratio: 16/9; overflow: hidden; }
  .video-thumbnail-link img { width: 100%; height: 100%; object-fit: cover; }
  .video-play-overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.3); transition: background 0.3s ease; }
  .video-thumbnail-link:hover .video-play-overlay { background: rgba(0,0,0,0.5); }
  .video-play-overlay svg { filter: drop-shadow(0 2px 8px rgba(0,0,0,0.4)); transition: transform 0.3s ease; }
  .video-thumbnail-link:hover .video-play-overlay svg { transform: scale(1.15); }
  .video-placeholder { aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center; background: var(--bg-alt); color: var(--accent); }
  .emission-cta { text-align: center; }
  .episodes { display: flex; flex-direction: column; }
  .episode-item { display: flex; align-items: center; gap: 1rem; padding: 1.25rem 0; border-bottom: 1px solid var(--border); text-decoration: none; transition: all 0.2s ease; }
  .episode-item:first-child { padding-top: 0; }
  .episode-item:hover { padding-left: 0.5rem; }
  .episode-item:hover .episode-arrow { color: var(--accent); transform: translateX(3px); }
  .episode-num { font-family: var(--font-display); font-size: 0.85rem; font-weight: 500; color: var(--accent); min-width: 2.5rem; }
  .episode-info { flex: 1; }
  .episode-info h4 { font-family: var(--font-display); font-size: 0.95rem; font-weight: 500; margin-bottom: 0.2rem; }
  .episode-date { font-size: 0.72rem; color: var(--muted); }
  .episode-arrow { color: var(--border-strong); transition: all 0.2s ease; flex-shrink: 0; }
  .episodes-placeholder { text-align: center; padding: 2rem 0; }
  .episodes-placeholder p { font-size: 0.95rem; color: var(--muted); margin-bottom: 1rem; }
  @media (max-width: 768px) { .emission-grid { grid-template-columns: 1fr; } }
</style>
