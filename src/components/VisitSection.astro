<section id="visiter" class="visit-section">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-overline">Visiter</p>
      <h2 class="section-title">Maison <em>Sainte-Geneviève</em></h2>
    </div>
    <div class="visit-grid reveal">
      <div class="visit-info">
        <div class="visit-card">
          <h3>Adresse</h3>
          <p>Séminaire orthodoxe russe<br/>4, rue Sainte-Geneviève<br/>91860 Épinay-sous-Sénart</p>
          <p class="visit-detail">À 15 min à pied de la gare RER de Brunoy (ligne D), facilement accessible depuis Paris.</p>
        </div>
        <div class="visit-card">
          <h3>Horaires de visite</h3>
          <p>Samedi et dimanche<br/>14 h — 18 h</p>
          <p class="visit-detail">Le séminaire est également ouvert au public aux horaires des célébrations liturgiques.</p>
        </div>
        <div class="visit-card">
          <h3>Librairie</h3>
          <p>Éditions Sainte-Geneviève, icônes, miel, encens, cierges et objets artisanaux.</p>
          <p class="visit-detail">6, rue Sainte-Geneviève — samedi et dimanche, 14 h — 18 h</p>
        </div>
      </div>
      <div class="visit-map">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2632.5!2d2.5317!3d48.6883!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sS%C3%A9minaire+Orthodoxe+Russe+Sainte-Genevi%C3%A8ve!5e0!3m2!1sfr!2sfr!4v1" width="100%" height="100%" style="border:0; border-radius: 16px; min-height: 400px;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Localisation du séminaire"></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .visit-section { background: var(--bg-alt); transition: background 0.4s ease; }
  .visit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
  .visit-info { display: flex; flex-direction: column; gap: 1.5rem; }
  .visit-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; }
  .visit-card h3 { font-family: var(--font-display); font-size: 1rem; font-weight: 500; font-style: italic; color: var(--accent); margin-bottom: 0.75rem; }
  .visit-card p { font-size: 0.9rem; line-height: 1.6; }
  .visit-detail { font-size: 0.82rem !important; color: var(--muted) !important; margin-top: 0.5rem; }
  .visit-map { border-radius: 16px; overflow: hidden; min-height: 400px; }
  @media (max-width: 768px) { .visit-grid { grid-template-columns: 1fr; } }
</style>
