---
import { getLiturgySchedule } from '../lib/strapi';

const schedule = await getLiturgySchedule();
---

<section id="liturgie" class="liturgy-section">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-overline">Vie liturgique</p>
      <h2 class="section-title">La prière <em>quotidienne</em></h2>
    </div>

    <div class="liturgy-grid reveal">
      <div class="churches">
        <div class="church-card">
          <div class="church-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7v15h8v-6h4v6h8V7L12 2z"/><path d="M12 2v5M12 7v2"/></svg>
          </div>
          <h3>Chapelle Sainte-Geneviève-et-Saint-Martin</h3>
          <p>Chapelle intérieure du séminaire, où les séminaristes célèbrent les offices quotidiens.</p>
        </div>
        <div class="church-card">
          <div class="church-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7v15h8v-6h4v6h8V7L12 2z"/><path d="M12 2v5M12 7v2"/></svg>
          </div>
          <h3>Église Notre-Dame de la Nativité</h3>
          <p>Église paroissiale du séminaire, ouverte aux fidèles pour les célébrations dominicales et festives.</p>
        </div>

        {schedule?.length > 0 && (
          <div class="schedule-card">
            <h3>Prochaines célébrations</h3>
            <ul class="schedule-list">
              {schedule.map(item => (
                <li>
                  <span class="schedule-date">{new Date(item.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' })}</span>
                  <span class="schedule-title">{item.title}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <div class="livestream-card">
        <div class="live-badge"><span class="live-dot"></span>En direct</div>
        <h3>Suivez nos célébrations en direct</h3>
        <p>Toutes nos célébrations sont retransmises en direct sur notre chaîne YouTube. Unissez-vous à la prière du séminaire où que vous soyez.</p>
        <a href="https://www.youtube.com/@seminaireorthodoxe" target="_blank" rel="noopener" class="btn btn-accent">▶ Regarder en direct</a>
      </div>
    </div>
  </div>
</section>

<style>
  .liturgy-section { background: var(--bg-alt); transition: background 0.4s ease; }
  .liturgy-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
  .churches { display: flex; flex-direction: column; gap: 1.5rem; }
  .church-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 2rem; transition: all 0.3s ease; }
  .church-card:hover { box-shadow: var(--shadow-hover); }
  .church-icon { color: var(--accent); margin-bottom: 1rem; }
  .church-card h3 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 500; margin-bottom: 0.5rem; }
  .church-card p { font-size: 0.9rem; line-height: 1.6; color: var(--muted); }
  .schedule-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 2rem; }
  .schedule-card h3 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 500; font-style: italic; color: var(--accent); margin-bottom: 1rem; }
  .schedule-list { list-style: none; }
  .schedule-list li { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid var(--border); font-size: 0.9rem; }
  .schedule-date { color: var(--muted); }
  .schedule-title { font-weight: 500; }
  .livestream-card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 2.5rem; display: flex; flex-direction: column; justify-content: center; }
  .live-badge { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #c41e3a; margin-bottom: 1.5rem; }
  .live-dot { width: 8px; height: 8px; border-radius: 50%; background: #c41e3a; animation: scrollPulse 1.5s ease-in-out infinite; }
  .livestream-card h3 { font-family: var(--font-display); font-size: 1.3rem; font-weight: 500; margin-bottom: 1rem; }
  .livestream-card p { font-size: 0.95rem; line-height: 1.7; color: var(--muted); margin-bottom: 1.5rem; }
  @media (max-width: 768px) { .liturgy-grid { grid-template-columns: 1fr; } }
</style>
