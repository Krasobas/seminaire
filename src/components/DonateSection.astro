<section class="donate-section">
  <div class="container">
    <div class="donate-inner reveal">
      <div class="donate-text">
        <p class="section-overline">Soutenir</p>
        <h2 class="section-title">Soutenir la formation et la <em>prière</em> de l'Église</h2>
        <p class="donate-desc">Votre don soutient la formation des séminaristes, la prière quotidienne et la retransmission des célébrations. Si vous êtes imposable, les dons ouvrent droit à une déduction d'impôt de 66%.</p>
      </div>
      <div class="donate-actions">
        <a href="/faire-don" class="btn btn-accent" style="font-size: 0.9rem; padding: 1rem 2.5rem;">Faire un don</a>
        <div class="donate-methods"><span>Carte bancaire · PayPal · Chèque · Virement</span></div>
      </div>
    </div>
  </div>
</section>

<style>
  .donate-section { padding: 4rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .donate-inner { display: flex; justify-content: space-between; align-items: center; gap: 3rem; }
  .donate-desc { font-size: 1rem; line-height: 1.7; color: var(--muted); margin-top: 1rem; max-width: 520px; }
  .donate-actions { text-align: center; flex-shrink: 0; }
  .donate-methods { margin-top: 1rem; }
  .donate-methods span { font-size: 0.72rem; color: var(--muted); letter-spacing: 0.02em; }
  @media (max-width: 768px) { .donate-inner { flex-direction: column; text-align: center; } .donate-desc { max-width: 100%; } }
</style>
