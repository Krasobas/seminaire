{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Actualités et nouvelles du séminaire"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "content": {
      "type": "richtext"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "category": {
      "type": "enumeration",
      "enum": ["Vie liturgique", "Émission", "Communiqué", "Formation", "Pèlerinage", "Admissions"],
      "default": "Communiqué"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
